{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ Next.js dev server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🗄 DB: Run migrations",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/db/migrate.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "✅ Run tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/tests/run.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🕷 Scrape ALL + save",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scheduler/runAll.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🕷 Preview: Organic Mandya (no save)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scrapers/organicMandya.js",
