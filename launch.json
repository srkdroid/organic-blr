{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ Next.js dev server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🗄 DB: Run migrations",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/db/migrate.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "✅ Run tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/tests/run.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🕷 Scrape: ALL providers",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scheduler/runAll.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🕷 Scrape: Organic Mandya (fastest — no browser)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scrapers/organicMandya.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🕷 Scrape: Lushful (no browser)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scrapers/lushful.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🕷 Scrape: Farm Fresh (no browser)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scrapers/farmFresh.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🕷 Scrape: Healthy Buddha",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scrapers/healthyBuddha.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🕷 Scrape: Akshayakalpa",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scrapers/akshayakalpa.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "🕷 Scrape: GreenDNA",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scrapers/greenDNA.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "⏰ Start cron scheduler",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scraper/scheduler/cron.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
