# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is listed in .gitignore — it will NEVER be committed to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — Transaction Pooler URL (port 6543)
# Location: Supabase Dashboard → Settings → Database → Transaction pooler → URI
# Replace [project-ref] and [password] with your actual values.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# A secret string you choose — used to bust the Vercel cache from the UI.
# Pick anything: "mango2024!" or "organicblr_secret" etc.
SCRAPE_TRIGGER_SECRET=change_me_to_any_secret_string

# GST rate (5% for fresh produce in India)
GST_RATE=0.05

# App name (shown in browser tab)
NEXT_PUBLIC_APP_NAME=Organic Bangalore
