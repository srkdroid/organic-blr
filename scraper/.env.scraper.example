# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to scraper/.env.scraper and fill in your values.
# This file is used ONLY by the local scraper — NOT by Next.js or Vercel.
# scraper/.env.scraper is in .gitignore — it will NEVER be committed to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — Direct Connection URL (port 5432)
# Location: Supabase Dashboard → Settings → Database → Direct connection → URI
# This is DIFFERENT from .env.local — it bypasses the pooler for persistent connections.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Scraper behaviour
SCRAPE_HEADLESS=true
# Set to false to watch the browser open while debugging a scraper:
# SCRAPE_HEADLESS=false

SCRAPE_TIMEOUT_MS=30000
SCRAPE_RETRY_COUNT=3
SCRAPE_RETRY_DELAY_MS=2000

# Cron schedule (uses node-cron format)
CRON_MORNING=0 6 * * *
CRON_EVENING=0 16 * * *

# Tax rate
GST_RATE=0.05

# Notifications (Optional)
# Fill these in to receive alerts when a scrape cycle finishes or fails
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
